NEXT_PUBLIC_SUPABASE_URL=https://supabase.growyourbiz.africa
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:password@supabase.growyourbiz.africa:5432/postgres
OPENAI_API_KEY=your_openai_key_here
# Claude is the primary AI extraction model (task 0.6). When set, the AI
# analyser uses Anthropic and ignores OPENAI_API_KEY. Optional override:
# ANTHROPIC_MODEL (defaults to claude-opus-4-8).
ANTHROPIC_API_KEY=your_anthropic_key_here
CRON_SECRET=generate_a_random_32_char_string_here
NEXT_PUBLIC_APP_URL=https://growyourbizsa.co.za
